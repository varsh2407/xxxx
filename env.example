# ─── Azure OpenAI Configuration ─────────────────────────────────────────────
# Your Azure OpenAI resource API key
AZURE_API_KEY=your_azure_openai_api_key_here

# Your Azure OpenAI resource endpoint
AZURE_API_BASE=https://your-resource-name.openai.azure.com/

# Azure OpenAI API version
AZURE_API_VERSION=2024-02-01

# The deployment name you created in Azure OpenAI Studio
# Recommended: gpt-4o or gpt-4-turbo for best code generation quality
AZURE_DEPLOYMENT=gpt-4o

# ─── GitHub Publishing (optional) ────────────────────────────────────────────
# Personal Access Token with scopes: repo, workflow
# Create at: https://github.com/settings/tokens/new
GITHUB_TOKEN=ghp_your_token_here

# Your GitHub username
GITHUB_USERNAME=your_github_username

# Optional: push to an org instead of your personal account
# GITHUB_ORG=your_org_name
